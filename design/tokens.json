{
  "$name": "Kinetika Design Tokens",
  "$version": "2.3.0",
  "$description": "ir0nm0nk visual identity — source of truth. tokens.css is generated from this file via build-tokens.mjs. Agents: read this file directly; it follows the W3C Design Tokens draft format (aliases use {dot.path} syntax).",

  "font": {
    "display": { "$type": "fontFamily", "$value": ["Cormorant Garamond", "Georgia", "serif"], "$description": "The soul of the system — titles, hero text, editorial moments" },
    "interface": { "$type": "fontFamily", "$value": ["Syne", "system-ui", "sans-serif"], "$description": "The structure of the system — UI labels, navigation, body, headings" },
    "technical": { "$type": "fontFamily", "$value": ["DM Mono", "Courier New", "monospace"], "$description": "The honesty of the system — data, terminal output, code, metrics" }
  },

  "color": {
    "raw": {
      "linen":        { "$type": "color", "$value": "#F5F1EB", "$description": "Light mode base background" },
      "cloud-dancer": { "$type": "color", "$value": "#EDE8E0", "$description": "Primary text (dark), surface (light)" },
      "pale-alloy":   { "$type": "color", "$value": "#C8C4BE", "$description": "Secondary text, UI elements" },
      "iron-mist":    { "$type": "color", "$value": "#8A8680", "$description": "Tertiary text (dark), disabled (light)" },
      "graphite":     { "$type": "color", "$value": "#4A4A48", "$description": "Disabled text (dark)" },
      "ash":          { "$type": "color", "$value": "#3A3A38", "$description": "Ghost text, strong borders (dark)" },
      "forge":        { "$type": "color", "$value": "#252523", "$description": "Borders, dividers, overlays (dark)" },
      "coal":         { "$type": "color", "$value": "#1E1E1C", "$description": "Elevated surfaces, subtle borders (dark)" },
      "ember":        { "$type": "color", "$value": "#1C1C1B", "$description": "Main app background (dark) — warm, not pure black" },
      "void":         { "$type": "color", "$value": "#161615", "$description": "Cards, sidebar, panels (dark)" },
      "soot":         { "$type": "color", "$value": "#111110", "$description": "Statusbar, deepest layer (dark)" },

      "patina":           { "$type": "color", "$value": "#8C6A3A", "$description": "Accent primary — mid patina. Borders & large UI on dark (3.4:1); use patina-bright for text" },
      "patina-bright":    { "$type": "color", "$value": "#C0905A", "$description": "Patina for text on dark backgrounds (6.0:1 on ember)" },
      "patina-deep":      { "$type": "color", "$value": "#2A1C10", "$description": "Dark bg for patina badges" },
      "patina-mid":       { "$type": "color", "$value": "#5A3A22", "$description": "Patina border (dark)" },
      "patina-light":     { "$type": "color", "$value": "#F0E8DC", "$description": "Light bg for patina badges" },
      "patina-text-light":{ "$type": "color", "$value": "#7A5228", "$description": "Patina text on light bg (6.1:1 on linen)" },

      "verdigris":            { "$type": "color", "$value": "#5A7A6A", "$description": "Accent secondary — full patina. Borders & large UI on dark (3.6:1); use verdigris-bright for text" },
      "verdigris-bright":     { "$type": "color", "$value": "#85AE99", "$description": "Verdigris for text on dark backgrounds (6.9:1 on ember)" },
      "verdigris-deep":       { "$type": "color", "$value": "#101A18", "$description": "Dark bg for verdigris badges" },
      "verdigris-mid":        { "$type": "color", "$value": "#2A4A42", "$description": "Verdigris border (dark)" },
      "verdigris-light":      { "$type": "color", "$value": "#DFF0EA", "$description": "Light bg for verdigris badges" },
      "verdigris-text-light": { "$type": "color", "$value": "#3A6A5A", "$description": "Verdigris text on light bg (5.1:1 on linen)" },

      "copper": { "$type": "color", "$value": "#BE8E50", "$description": "Live status on dark (5.8:1) — copper glow" },
      "amber":  { "$type": "color", "$value": "#CFA268", "$description": "Warning status on dark (7.3:1) — heated metal" },
      "rust":   { "$type": "color", "$value": "#D4663F", "$description": "Error status on dark (4.7:1) — oxidized iron" },

      "azure":            { "$type": "color", "$value": "#5E7693", "$description": "Accent — azurite blue (oxidized copper carbonate). Borders & large UI on dark (3.7:1); use azure-bright for text" },
      "azure-bright":     { "$type": "color", "$value": "#8FB2D2", "$description": "Azure for text on dark backgrounds (7.7:1 on ember)" },
      "azure-deep":       { "$type": "color", "$value": "#0E1620", "$description": "Dark bg for azure badges" },
      "azure-mid":        { "$type": "color", "$value": "#2C4056", "$description": "Azure border (dark)" },
      "azure-light":      { "$type": "color", "$value": "#DEE8F2", "$description": "Light bg for azure badges" },
      "azure-text-light": { "$type": "color", "$value": "#3C5C7C", "$description": "Azure text on light bg (6.2:1 on linen)" },

      "teal":            { "$type": "color", "$value": "#4E8890", "$description": "Accent — chrysocolla teal (hydrated copper). Borders & large UI on dark (4.3:1); use teal-bright for text" },
      "teal-bright":     { "$type": "color", "$value": "#7DBDC6", "$description": "Teal for text on dark backgrounds (8.1:1 on ember)" },
      "teal-deep":       { "$type": "color", "$value": "#0C1A1C", "$description": "Dark bg for teal badges" },
      "teal-mid":        { "$type": "color", "$value": "#234E54", "$description": "Teal border (dark)" },
      "teal-light":      { "$type": "color", "$value": "#D8F0F3", "$description": "Light bg for teal badges" },
      "teal-text-light": { "$type": "color", "$value": "#2E6A74", "$description": "Teal text on light bg (5.4:1 on linen)" },

      "amethyst":            { "$type": "color", "$value": "#7E6C9E", "$description": "Accent — manganese violet (oxidized manganese). Borders & large UI on dark (3.7:1); use amethyst-bright for text" },
      "amethyst-bright":     { "$type": "color", "$value": "#B5A4D6", "$description": "Amethyst for text on dark backgrounds (7.5:1 on ember)" },
      "amethyst-deep":       { "$type": "color", "$value": "#161020", "$description": "Dark bg for amethyst badges" },
      "amethyst-mid":        { "$type": "color", "$value": "#40365C", "$description": "Amethyst border (dark)" },
      "amethyst-light":      { "$type": "color", "$value": "#E9E2F4", "$description": "Light bg for amethyst badges" },
      "amethyst-text-light": { "$type": "color", "$value": "#5C4E7E", "$description": "Amethyst text on light bg (6.6:1 on linen)" },

      "garnet":            { "$type": "color", "$value": "#A05E72", "$description": "Accent — garnet rose (iron-aluminium silicate). Borders & large UI on dark (3.5:1); use garnet-bright for text" },
      "garnet-bright":     { "$type": "color", "$value": "#D498A8", "$description": "Garnet for text on dark backgrounds (7.2:1 on ember)" },
      "garnet-deep":       { "$type": "color", "$value": "#200E14", "$description": "Dark bg for garnet badges" },
      "garnet-mid":        { "$type": "color", "$value": "#5A2C3A", "$description": "Garnet border (dark)" },
      "garnet-light":      { "$type": "color", "$value": "#F2E0E6", "$description": "Light bg for garnet badges" },
      "garnet-text-light": { "$type": "color", "$value": "#8C3C52", "$description": "Garnet text on light bg (6.5:1 on linen)" }
    },

    "dark": {
      "$description": "Default theme. In-between neutral shades without a raw alias are intentional one-offs.",
      "bg-base":      { "$value": "{color.raw.ember}" },
      "bg-surface":   { "$value": "{color.raw.void}" },
      "bg-elevated":  { "$value": "{color.raw.coal}" },
      "bg-sunken":    { "$value": "{color.raw.soot}" },
      "bg-overlay":   { "$value": "{color.raw.forge}" },

      "text-primary":   { "$value": "{color.raw.cloud-dancer}" },
      "text-secondary": { "$value": "{color.raw.pale-alloy}" },
      "text-tertiary":  { "$value": "{color.raw.iron-mist}", "$description": "4.7:1 on ember — AA" },
      "text-disabled":  { "$value": "{color.raw.graphite}", "$description": "Decorative only — below AA by design" },
      "text-ghost":     { "$value": "{color.raw.ash}", "$description": "Decorative only — barely visible by design" },

      "border-strong":  { "$value": "{color.raw.ash}" },
      "border-default": { "$value": "{color.raw.forge}" },
      "border-subtle":  { "$value": "{color.raw.coal}" },

      "accent-primary":        { "$value": "{color.raw.patina}" },
      "accent-primary-bg":     { "$value": "{color.raw.patina-deep}" },
      "accent-primary-border": { "$value": "{color.raw.patina-mid}" },
      "accent-primary-text":   { "$value": "{color.raw.patina-bright}" },

      "accent-secondary":        { "$value": "{color.raw.verdigris}" },
      "accent-secondary-bg":     { "$value": "{color.raw.verdigris-deep}" },
      "accent-secondary-border": { "$value": "{color.raw.verdigris-mid}" },
      "accent-secondary-text":   { "$value": "{color.raw.verdigris-bright}" },

      "accent-azure":        { "$value": "{color.raw.azure}" },
      "accent-azure-bg":     { "$value": "{color.raw.azure-deep}" },
      "accent-azure-border": { "$value": "{color.raw.azure-mid}" },
      "accent-azure-text":   { "$value": "{color.raw.azure-bright}" },

      "accent-teal":        { "$value": "{color.raw.teal}" },
      "accent-teal-bg":     { "$value": "{color.raw.teal-deep}" },
      "accent-teal-border": { "$value": "{color.raw.teal-mid}" },
      "accent-teal-text":   { "$value": "{color.raw.teal-bright}" },

      "accent-amethyst":        { "$value": "{color.raw.amethyst}" },
      "accent-amethyst-bg":     { "$value": "{color.raw.amethyst-deep}" },
      "accent-amethyst-border": { "$value": "{color.raw.amethyst-mid}" },
      "accent-amethyst-text":   { "$value": "{color.raw.amethyst-bright}" },

      "accent-garnet":        { "$value": "{color.raw.garnet}" },
      "accent-garnet-bg":     { "$value": "{color.raw.garnet-deep}" },
      "accent-garnet-border": { "$value": "{color.raw.garnet-mid}" },
      "accent-garnet-text":   { "$value": "{color.raw.garnet-bright}" },

      "status-live":    { "$value": "{color.raw.copper}" },
      "status-online":  { "$value": "{color.raw.verdigris}", "$description": "Dot/large UI: 3.6:1. As text use verdigris-bright" },
      "status-warning": { "$value": "{color.raw.amber}" },
      "status-error":   { "$value": "{color.raw.rust}" }
    },

    "light": {
      "bg-base":      { "$value": "{color.raw.linen}" },
      "bg-surface":   { "$value": "{color.raw.cloud-dancer}" },
      "bg-elevated":  { "$value": "#E8E3DB" },
      "bg-sunken":    { "$value": "#D4CFC8" },
      "bg-overlay":   { "$value": "#FDFAF6" },

      "text-primary":   { "$value": "{color.raw.ember}" },
      "text-secondary": { "$value": "#2E2E2C" },
      "text-tertiary":  { "$value": "#5A5A58", "$description": "6.1:1 on linen — AA" },
      "text-disabled":  { "$value": "{color.raw.iron-mist}", "$description": "Decorative only — below AA by design" },
      "text-ghost":     { "$value": "#B8B3AC", "$description": "Decorative only — barely visible by design" },

      "border-strong":  { "$value": "#B8B3AC" },
      "border-default": { "$value": "#D4CFC8" },
      "border-subtle":  { "$value": "#E0DBD4" },

      "accent-primary":        { "$value": "{color.raw.patina}" },
      "accent-primary-bg":     { "$value": "{color.raw.patina-light}" },
      "accent-primary-border": { "$value": "#C8A878" },
      "accent-primary-text":   { "$value": "{color.raw.patina-text-light}" },

      "accent-secondary":        { "$value": "{color.raw.verdigris}" },
      "accent-secondary-bg":     { "$value": "{color.raw.verdigris-light}" },
      "accent-secondary-border": { "$value": "#8ABCAC" },
      "accent-secondary-text":   { "$value": "{color.raw.verdigris-text-light}" },

      "accent-azure":        { "$value": "{color.raw.azure}" },
      "accent-azure-bg":     { "$value": "{color.raw.azure-light}" },
      "accent-azure-border": { "$value": "#9DB2CC" },
      "accent-azure-text":   { "$value": "{color.raw.azure-text-light}" },

      "accent-teal":        { "$value": "{color.raw.teal}" },
      "accent-teal-bg":     { "$value": "{color.raw.teal-light}" },
      "accent-teal-border": { "$value": "#92BFC6" },
      "accent-teal-text":   { "$value": "{color.raw.teal-text-light}" },

      "accent-amethyst":        { "$value": "{color.raw.amethyst}" },
      "accent-amethyst-bg":     { "$value": "{color.raw.amethyst-light}" },
      "accent-amethyst-border": { "$value": "#B7A9D2" },
      "accent-amethyst-text":   { "$value": "{color.raw.amethyst-text-light}" },

      "accent-garnet":        { "$value": "{color.raw.garnet}" },
      "accent-garnet-bg":     { "$value": "{color.raw.garnet-light}" },
      "accent-garnet-border": { "$value": "#CFA0AE" },
      "accent-garnet-text":   { "$value": "{color.raw.garnet-text-light}" },

      "status-live":    { "$value": "#855E34", "$description": "4.7:1 on cloud dancer" },
      "status-online":  { "$value": "#4A6658", "$description": "5.2:1 on cloud dancer" },
      "status-warning": { "$value": "#7E5A30", "$description": "5.1:1 on cloud dancer" },
      "status-error":   { "$value": "#A32D2D", "$description": "5.8:1 on cloud dancer" }
    },

    "component": {
      "$description": "Theme-scoped component colors — emitted as bare CSS vars (e.g. --card-active-bg)",
      "dark": {
        "card-active-bg":     { "$value": "#1A1410", "$description": "Active card — warm ember tint. Decorative: border + accent carry the state, never bg alone" },
        "btn-primary-bg":     { "$value": "{color.raw.patina-bright}", "$description": "Primary button — inverted (light bg, dark text) for AA: text is 6.0:1" },
        "btn-primary-text":   { "$value": "{color.raw.ember}" },
        "input-border-color": { "$value": "{color.raw.iron-mist}", "$description": "≥3:1 non-text contrast on base/surface/elevated (WCAG 1.4.11)" }
      },
      "light": {
        "card-active-bg":     { "$value": "#EAE0D4", "$description": "Active card — warm linen tint. Decorative: border + accent carry the state, never bg alone" },
        "btn-primary-bg":     { "$value": "{color.raw.patina-text-light}", "$description": "Primary button — text is 6.1:1" },
        "btn-primary-text":   { "$value": "{color.raw.linen}" },
        "input-border-color": { "$value": "#807C76", "$description": "≥3:1 on base/surface/elevated — iron-mist is too light against cloud-dancer" }
      }
    }
  },

  "shadow": {
    "$description": "Warm-tinted shadows — never pure black",
    "dark": {
      "sm": { "$value": "0 1px 2px rgba(12, 10, 8, 0.50)" },
      "md": { "$value": "0 2px 8px rgba(12, 10, 8, 0.45)" },
      "lg": { "$value": "0 8px 24px rgba(12, 10, 8, 0.50)" }
    },
    "light": {
      "sm": { "$value": "0 1px 2px rgba(28, 28, 27, 0.08)" },
      "md": { "$value": "0 2px 8px rgba(28, 28, 27, 0.10)" },
      "lg": { "$value": "0 8px 24px rgba(28, 28, 27, 0.14)" }
    }
  },

  "text": {
    "$description": "rem-based so user font-size preferences are respected. px equivalents assume 16px root.",
    "xs":  { "$value": "0.6875rem", "$description": "11px — minimum size in the system" },
    "sm":  { "$value": "0.75rem",   "$description": "12px" },
    "base":{ "$value": "0.8125rem", "$description": "13px — code, dense UI" },
    "md":  { "$value": "0.875rem",  "$description": "14px — body text default" },
    "lg":  { "$value": "1rem",      "$description": "16px" },
    "xl":  { "$value": "1.125rem",  "$description": "18px" },
    "2xl": { "$value": "1.375rem",  "$description": "22px" },
    "3xl": { "$value": "1.75rem",   "$description": "28px" },
    "4xl": { "$value": "2.25rem",   "$description": "36px" },
    "5xl": { "$value": "3rem",      "$description": "48px" }
  },

  "weight": {
    "light":   { "$value": "300" },
    "regular": { "$value": "400" },
    "medium":  { "$value": "500" },
    "bold":    { "$value": "700" },
    "black":   { "$value": "800" }
  },

  "leading": {
    "tight":  { "$value": "1.1" },
    "snug":   { "$value": "1.3" },
    "normal": { "$value": "1.6" },
    "loose":  { "$value": "1.8" }
  },

  "tracking": {
    "tight":  { "$value": "-0.01em" },
    "normal": { "$value": "0em" },
    "wide":   { "$value": "0.06em" },
    "wider":  { "$value": "0.1em" },
    "widest": { "$value": "0.18em" }
  },

  "space": {
    "$description": "px by design — spatial rhythm stays fixed while type scales with user preference",
    "1":  { "$value": "4px" },
    "2":  { "$value": "8px" },
    "3":  { "$value": "12px" },
    "4":  { "$value": "16px" },
    "5":  { "$value": "20px" },
    "6":  { "$value": "24px" },
    "8":  { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" }
  },

  "radius": {
    "sm":   { "$value": "3px",    "$description": "Buttons, badges, tight elements" },
    "md":   { "$value": "6px",    "$description": "Cards, inputs" },
    "lg":   { "$value": "10px",   "$description": "Modals, panels, shell" },
    "full": { "$value": "9999px", "$description": "Pills" }
  },

  "border-width": {
    "hairline": { "$value": "0.5px", "$description": "Opt-in, hi-dpi displays only — renders as 0 or 1px at 1×" },
    "default":  { "$value": "1px" },
    "accent":   { "$value": "1px" },
    "strong":   { "$value": "2px" }
  },

  "duration": {
    "fast": { "$value": "120ms", "$description": "Hover, focus, small state changes" },
    "base": { "$value": "200ms", "$description": "Most transitions" },
    "slow": { "$value": "320ms", "$description": "Panels, modals, theme switch" }
  },

  "ease": {
    "standard": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",  "$description": "Default — mechanical, purposeful" },
    "out":      { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$description": "Entrances — settles like metal cooling" },
    "in":       { "$value": "cubic-bezier(0.7, 0, 0.84, 0)", "$description": "Exits" }
  },

  "motion": {
    "$description": "Semantic motion recipes — duration + easing fragments meant to be slotted into a `transition` or `animation` shorthand (e.g. `transition: transform var(--motion-transition)`, `animation: k-rise var(--motion-enter)`). Compose from these instead of pairing duration/ease by hand. Every recipe pulls its duration from --duration-*, so prefers-reduced-motion neutralizes them automatically.",
    "transition":      { "$value": "{duration.base} {ease.standard}", "$description": "Default state change — hovers, toggles, theme" },
    "transition-fast": { "$value": "{duration.fast} {ease.standard}", "$description": "Quick feedback — focus, small controls" },
    "enter":           { "$value": "{duration.base} {ease.out} both",   "$description": "Entrances — settle like cooling metal" },
    "exit":            { "$value": "{duration.fast} {ease.in} both",    "$description": "Exits" },
    "emphasis":        { "$value": "{duration.slow} {ease.standard} both", "$description": "Deliberate, weighty motion — panels, modals" }
  },

  "z": {
    "base":     { "$value": "0" },
    "sticky":   { "$value": "100" },
    "dropdown": { "$value": "200" },
    "overlay":  { "$value": "300" },
    "modal":    { "$value": "400" },
    "toast":    { "$value": "500" }
  },

  "type-role": {
    "$description": "Typography roles — emitted as --type-<role>-<prop>. Aliases: {color.semantic.x} → var(--color-x), everything else {group.key} → var(--group-key).",
    "display": {
      "$description": "Cormorant Garamond — the soul of the system",
      "font":    { "$value": "{font.display}" },
      "size":    { "$value": "{text.4xl}" },
      "weight":  { "$value": "{weight.light}" },
      "style":   { "$value": "italic" },
      "leading": { "$value": "{leading.tight}" }
    },
    "heading": {
      "$description": "Syne",
      "font":     { "$value": "{font.interface}" },
      "size":     { "$value": "{text.xl}" },
      "weight":   { "$value": "{weight.bold}" },
      "leading":  { "$value": "{leading.snug}" },
      "tracking": { "$value": "{tracking.tight}" }
    },
    "label": {
      "$description": "Syne — UI labels",
      "font":      { "$value": "{font.interface}" },
      "size":      { "$value": "{text.sm}" },
      "weight":    { "$value": "{weight.medium}" },
      "tracking":  { "$value": "{tracking.widest}" },
      "transform": { "$value": "uppercase" }
    },
    "body": {
      "$description": "Syne",
      "font":    { "$value": "{font.interface}" },
      "size":    { "$value": "{text.md}" },
      "weight":  { "$value": "{weight.regular}" },
      "leading": { "$value": "{leading.normal}" }
    },
    "caption": {
      "$description": "DM Mono",
      "font":     { "$value": "{font.technical}" },
      "size":     { "$value": "{text.xs}" },
      "weight":   { "$value": "{weight.regular}" },
      "tracking": { "$value": "{tracking.wider}" }
    },
    "data": {
      "$description": "DM Mono — data / metric",
      "font":    { "$value": "{font.technical}" },
      "size":    { "$value": "{text.md}" },
      "weight":  { "$value": "{weight.light}" },
      "leading": { "$value": "{leading.snug}" }
    },
    "code": {
      "$description": "DM Mono",
      "font":    { "$value": "{font.technical}" },
      "size":    { "$value": "{text.base}" },
      "weight":  { "$value": "{weight.regular}" },
      "leading": { "$value": "{leading.loose}" }
    }
  },

  "border": {
    "$description": "Composite border shorthands — emitted as --border-<name>",
    "default": { "$value": "{border-width.default} solid {color.semantic.border-default}" },
    "subtle":  { "$value": "{border-width.default} solid {color.semantic.border-subtle}" },
    "strong":  { "$value": "{border-width.default} solid {color.semantic.border-strong}" },
    "accent":  { "$value": "{border-width.accent} solid {color.semantic.accent-primary}" }
  },

  "focus": {
    "$description": "Focus ring — emitted as --focus-<name>",
    "ring-width":  { "$value": "2px" },
    "ring-offset": { "$value": "2px" },
    "ring":        { "$value": "{focus.ring-width} solid {color.semantic.accent-primary}" }
  },

  "component": {
    "$description": "Component tokens — emitted as --<component>-<prop>. Theme-scoped component COLORS live in color.component.",
    "sidebar": {
      "width":  { "$value": "200px" },
      "bg":     { "$value": "{color.semantic.bg-surface}" },
      "border": { "$value": "{border.subtle}" }
    },
    "topbar": {
      "bg":     { "$value": "{color.semantic.bg-sunken}" },
      "height": { "$value": "40px" }
    },
    "statusbar": {
      "height": { "$value": "28px" }
    },
    "card": {
      "bg":            { "$value": "{color.semantic.bg-surface}" },
      "border":        { "$value": "{border.default}" },
      "radius":        { "$value": "{radius.md}" },
      "padding":       { "$value": "{space.3} {space.4}" },
      "active-border": { "$value": "{color.semantic.accent-primary-border}" },
      "active-accent": { "$value": "{color.semantic.accent-primary}" }
    },
    "badge": {
      "font":     { "$value": "{font.technical}" },
      "size":     { "$value": "{text.xs}" },
      "padding":  { "$value": "3px 8px" },
      "radius":   { "$value": "{radius.sm}" },
      "tracking": { "$value": "{tracking.wider}" }
    },
    "btn": {
      "font":     { "$value": "{font.interface}" },
      "size":     { "$value": "{text.sm}" },
      "weight":   { "$value": "{weight.medium}" },
      "tracking": { "$value": "{tracking.wider}" },
      "padding":  { "$value": "7px 14px" },
      "radius":   { "$value": "{radius.sm}" }
    },
    "input": {
      "font":    { "$value": "{font.technical}" },
      "size":    { "$value": "{text.sm}" },
      "padding": { "$value": "7px 10px" },
      "radius":  { "$value": "{radius.sm}" },
      "border":  { "$value": "{border-width.default} solid {color.component.input-border-color}", "$description": "Uses input-border-color (≥3:1) — border-strong is decorative-only" }
    },
    "nav": {
      "font":     { "$value": "{font.interface}" },
      "size":     { "$value": "{text.sm}" },
      "tracking": { "$value": "{tracking.wide}" },
      "padding":  { "$value": "7px 16px" }
    },
    "section-label": {
      "font":      { "$value": "{font.technical}" },
      "size":      { "$value": "{text.xs}" },
      "tracking":  { "$value": "{tracking.widest}" },
      "transform": { "$value": "uppercase" },
      "color":     { "$value": "{color.semantic.text-ghost}" }
    }
  }
}
